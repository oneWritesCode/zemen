generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  username       String          @unique
  password       String
  profession     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  learnProgress  LearnProgress[]
  practiceScores PracticeScore[]
  quizResults    QuizResult[]
  profile        UserProfile?
  streak         UserStreak?
  watchlist      WatchlistItem[]

  @@map("users")
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  macroIqScore  Int      @default(0)
  level         String   @default("Beginner")
  totalXp       Int      @default(0)
  quizzesPlayed Int      @default(0)
  bestScore     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model QuizResult {
  id         String   @id @default(cuid())
  userId     String
  score      Int
  totalQ     Int
  percentage Float
  timeTaken  Int
  category   String   @default("general")
  answers    Json
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_results")
}

model LearnProgress {
  id        String    @id @default(cuid())
  userId    String
  topicSlug String
  topicName String
  completed Boolean   @default(false)
  readAt    DateTime?
  xpEarned  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicSlug])
  @@map("learn_progress")
}

model PracticeScore {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  score      Int
  maxScore   Int
  attempts   Int      @default(1)
  bestScore  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@map("practice_scores")
}

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  ticker       String
  name         String
  sector       String
  industry     String
  addedPrice   Float
  currentPrice Float    @default(0)
  notes        String?
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
  @@map("watchlist_items")
}

model UserStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastVisitDate DateTime?
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}
